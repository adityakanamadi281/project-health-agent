{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(uv run *)",
      "Bash(uv sync)",
      "Bash(uv add *)",
      "Bash(pytest*)",
      "Bash(ruff*)"
    ],
    "deny": [
      "Read(./.env)"
    ]
  },
  "env": {
    "UV_LINK_MODE": "copy"
  }
}
